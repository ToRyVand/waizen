# ====================================================================
#  Waizen — environment variables
#  Copy to .env and fill in. NEVER commit the real .env (it's gitignored).
# ====================================================================

# --- LLM (Google Gemini) ---
# Get an API key at: https://aistudio.google.com/app/apikey
# Tip: enable billing on the Google Cloud project for production-grade quota.
GOOGLE_API_KEY=your-gemini-api-key-here

# --- Panel login ---
# AUTH_HASH = bcrypt hash of your panel password. Generate it with:
#   python3 -c "import bcrypt;print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt(12)).decode())"
AUTH_HASH=

# AUTH_SECRET = random string used to sign session cookies.
# Leave empty to let the API generate one on first run.
AUTH_SECRET=

# --- WhatsApp agent (OpenClaw) ---
# Account id that binds this business to its WhatsApp number.
OPENCLAW_ACCOUNT=mybiz
